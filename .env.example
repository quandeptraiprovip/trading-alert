# Copy thành .env.local rồi điền giá trị thật (file .env.local KHÔNG commit).

# ── Telegram bot ────────────────────────────────────────────────────────────
# Bật/tắt Telegram (mặc định: false — bot chỉ log ra console)
TELEGRAM_ENABLED=false
# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Chat ID nhận alert — dùng @userinfobot hoặc https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# ── Kline cache (tuỳ chọn) ──────────────────────────────────────────────────
# KLINE_CACHE=0              # đặt = 0 để tắt cache đĩa (mặc định: bật)
# KLINE_FETCH_CONCURRENCY=4  # số request song song khi fetch nến (mặc định: 4)
